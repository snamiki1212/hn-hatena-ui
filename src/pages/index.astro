---
import HaLayout from "../layouts/HaLayout.astro";
import { getTopStoryIds, getStories } from "../api/hn/client";

const ids = await getTopStoryIds();
const stories = await getStories(ids, 30);
---

<HaLayout title="hn-hatena - トップ">
  <h1 class="page-title">トップストーリー</h1>
  <ul class="story-list">
    {stories.map((story, i) => (
      <li class="story-card">
        <div class="story-card__score">
          <span class="story-card__score-num">{story.score}</span>
          <span class="story-card__score-label">users</span>
        </div>
        <div class="story-card__body">
          <div class="story-card__rank">{i + 1}</div>
          <a href={story.url} target="_blank" rel="noopener" class="story-card__title">
            <span lang="ja">{story.titleJa ?? story.title}</span>
          </a>
          {story.titleJa && (
            <div class="story-card__title-en" lang="en">{story.title}</div>
          )}
          <div class="story-card__meta">
            <span class="story-card__by">{story.by}</span>
            <a href={`/hn-hatena-ui/story/${story.id}/`} class="story-card__comments">
              💬 {story.descendants} コメント
            </a>
          </div>
        </div>
      </li>
    ))}
  </ul>
</HaLayout>

<style>
  .page-title {
    font-size: 16px;
    font-weight: bold;
    color: #555;
    margin: 0 0 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid #0f4c81;
  }

  .story-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .story-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 4px;
    display: flex;
    gap: 12px;
    padding: 12px;
    transition: box-shadow 0.15s;
  }

  .story-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .story-card__score {
    flex-shrink: 0;
    width: 52px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #f0f5ff;
    border-radius: 4px;
    padding: 6px 4px;
  }

  .story-card__score-num {
    font-size: 18px;
    font-weight: bold;
    color: #0f4c81;
    line-height: 1;
  }

  .story-card__score-label {
    font-size: 10px;
    color: #888;
    margin-top: 2px;
  }

  .story-card__body {
    flex: 1;
    min-width: 0;
  }

  .story-card__rank {
    display: inline-block;
    font-size: 11px;
    color: #999;
    margin-bottom: 2px;
  }

  .story-card__title {
    display: block;
    font-size: 15px;
    font-weight: bold;
    color: #1a1a1a;
    line-height: 1.4;
    margin-bottom: 2px;
  }

  .story-card__title:hover {
    color: #0068c9;
    text-decoration: none;
  }

  .story-card__title-en {
    font-size: 11px;
    color: #999;
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .story-card__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    color: #888;
    margin-top: 6px;
  }

  .story-card__comments {
    color: #0068c9;
    font-size: 12px;
  }
</style>
