---
import HaLayout from "../../layouts/HaLayout.astro";
import { getStory, getTopStoryIds } from "../../api/hn/client";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const ids = await getTopStoryIds();
  const top = ids.slice(0, 30);
  return top.map((id) => ({ params: { id: String(id) } }));
};

const { id } = Astro.params;
const story = await getStory(Number(id));
---

<HaLayout title={story.titleJa ?? story.title}>
  <a href="/hn-hatena-ui/" class="back-link">← トップに戻る</a>
  <article class="story-detail">
    <div class="story-detail__header">
      <div class="story-detail__score">
        <span class="story-detail__score-num">{story.score}</span>
        <span class="story-detail__score-label">users</span>
      </div>
      <div class="story-detail__info">
        <h1 class="story-detail__title">
          <a href={story.url} target="_blank" rel="noopener">
            <span lang="ja">{story.titleJa ?? story.title}</span>
          </a>
        </h1>
        {story.titleJa && (
          <div class="story-detail__title-en" lang="en">{story.title}</div>
        )}
        <div class="story-detail__meta">
          <span>投稿者: <strong>{story.by}</strong></span>
          <span>💬 {story.descendants} コメント</span>
        </div>
      </div>
    </div>
    <!-- TODO: HaCommentSection (React Island) -->
    <div class="story-detail__comments-placeholder">
      <p>コメントセクションは実装予定です。</p>
    </div>
  </article>
</HaLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 13px;
    color: #0068c9;
    margin-bottom: 12px;
  }

  .story-detail {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 4px;
    padding: 20px;
  }

  .story-detail__header {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
  }

  .story-detail__score {
    flex-shrink: 0;
    width: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #f0f5ff;
    border-radius: 4px;
    padding: 10px 4px;
  }

  .story-detail__score-num {
    font-size: 24px;
    font-weight: bold;
    color: #0f4c81;
    line-height: 1;
  }

  .story-detail__score-label {
    font-size: 11px;
    color: #888;
    margin-top: 4px;
  }

  .story-detail__info {
    flex: 1;
    min-width: 0;
  }

  .story-detail__title {
    font-size: 18px;
    font-weight: bold;
    line-height: 1.4;
    margin: 0 0 4px;
  }

  .story-detail__title a {
    color: #1a1a1a;
  }

  .story-detail__title a:hover {
    color: #0068c9;
    text-decoration: none;
  }

  .story-detail__title-en {
    font-size: 12px;
    color: #999;
    margin-bottom: 8px;
  }

  .story-detail__meta {
    display: flex;
    gap: 16px;
    font-size: 13px;
    color: #666;
  }

  .story-detail__comments-placeholder {
    border-top: 1px solid #e8e8e8;
    padding-top: 16px;
    color: #999;
    font-size: 13px;
  }
</style>
